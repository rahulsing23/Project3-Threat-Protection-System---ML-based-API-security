# ML Service Environment Variables
# Copy this to .env and set your values

HOST=0.0.0.0
PORT=8090
LOG_LEVEL=INFO

# Path where the trained model is saved/loaded
MODEL_PATH=models/threat_model.joblib
MODEL_VERSION=1.0.0

# Thresholds (0.0 - 1.0)
BLOCK_THRESHOLD=0.80
CAPTCHA_THRESHOLD=0.60
MONITOR_THRESHOLD=0.40

# Minimum labeled samples required for retraining
MIN_TRAINING_SAMPLES=50

# CORS
ALLOWED_ORIGINS=["*"]